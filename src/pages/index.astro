  <div class="copyright">© 2026 Grace's Chinese Classroom · Learning Chinese on a summer hillside</div>
</footer>

<script>
  // Card fade-in on scroll
  const cards = document.querySelectorAll('.card');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.classList.add('in-view');
        io.unobserve(e.target);
      }
    });
  }, {threshold:0.15});
  cards.forEach(c=>io.observe(c));

  // Teaching journey: fade in each item + grow the line as progress
  const journeyItems = document.querySelectorAll('.journey-item');
  const journeyFill = document.getElementById('journeyFill');
  if(journeyItems.length){
    const jIo = new IntersectionObserver((entries)=>{
      entries.forEach(e=>{
        if(e.isIntersecting) e.target.classList.add('in-view');
      });
      const doneCount = document.querySelectorAll('.journey-item.in-view').length;
      if(journeyFill){
        journeyFill.style.height = (doneCount / journeyItems.length * 100) + '%';
      }
    }, {threshold:0.4});
    journeyItems.forEach(item=>jIo.observe(item));
  }

  // ---------- LOGO right-click menu (Grace brand version, no third-party dependency) ----------
  (function(){
    // Standalone mark (leaf) — used for "copy/download mark"
    const MARK_SVG = `<svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M12 3C9 7 6 9 6 13a6 6 0 0012 0c0-4-3-6-6-10z" fill="#82b968"/>
  <path d="M12 6c-1.8 2.7-3.6 4.2-3.6 6.8A3.6 3.6 0 0012 16.4" stroke="#5f9a52" stroke-width="1" fill="none" stroke-linecap="round"/>
</svg>`;

    // Full logo (leaf + wordmark) — used for "copy/download logo"
    const LOGO_SVG = `<svg width="300" height="56" viewBox="0 0 300 56" xmlns="http://www.w3.org/2000/svg">
  <g transform="translate(6,10)">
    <path d="M12 3C9 7 6 9 6 13a6 6 0 0012 0c0-4-3-6-6-10z" fill="#82b968"/>
    <path d="M12 6c-1.8 2.7-3.6 4.2-3.6 6.8A3.6 3.6 0 0012 16.4" stroke="#5f9a52" stroke-width="1" fill="none" stroke-linecap="round"/>
  </g>
  <text x="42" y="35" font-family="'Fraunces', serif" font-size="18" font-weight="700" fill="#8a5f30">Grace's Chinese Classroom</text>
</svg>`;

    const PALETTE = [
      {label:'Sky Blue',    value:'#BFE3F0'},
      {label:'Grass Green', value:'#5F9A52'},
      {label:'Sun Yellow',  value:'#F6D776'},
      {label:'Earth Brown', value:'#A6743F'},
      {label:'Cream White', value:'#FFFCF3'},
    ];

    const logoEl = document.querySelector('[data-rcl-logo]');
    if(!logoEl) return;

    // Build menu DOM
    const menu = document.createElement('div');
    menu.className = 'rcl-menu';
    menu.setAttribute('role','menu');
    menu.innerHTML = `
      <div class="rcl-title">Grace's Chinese Classroom · Brand Assets</div>
      <button class="rcl-item" data-action="copy-mark" role="menuitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 012-2h10"/></svg>
        Copy mark (SVG)
        <span class="rcl-check">✓ Copied</span>
      </button>
      <button class="rcl-item" data-action="copy-logo" role="menuitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 012-2h10"/></svg>
        Copy full logo (SVG)
        <span class="rcl-check">✓ Copied</span>
      </button>
      <div class="rcl-sep"></div>
      <button class="rcl-item" data-action="download-mark" role="menuitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v12m0 0l-4-4m4 4l4-4"/><path d="M5 19h14"/></svg>
        Download mark (SVG)
      </button>
      <button class="rcl-item" data-action="download-logo" role="menuitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v12m0 0l-4-4m4 4l4-4"/><path d="M5 19h14"/></svg>
        Download full logo (SVG)
      </button>
      <div class="rcl-sep"></div>
      <div class="rcl-title">Brand Palette · Click to copy</div>
      <div class="rcl-palette">
        ${PALETTE.map(c=>`<div class="rcl-swatch" style="background:${c.value}" data-color="${c.value}" data-label="${c.label} ${c.value}" title="${c.label} ${c.value}"></div>`).join('')}
      </div>
    `;
    document.body.appendChild(menu);

    function openMenu(x, y){
      menu.classList.add('open');
      const rect = menu.getBoundingClientRect();
      const vw = window.innerWidth, vh = window.innerHeight;
      const left = Math.min(x, vw - rect.width - 12);
      const top  = Math.min(y, vh - rect.height - 12);
      menu.style.left = Math.max(12,left) + 'px';
      menu.style.top  = Math.max(12,top) + 'px';
    }
    function closeMenu(){ menu.classList.remove('open'); }

    function downloadSVG(svgString, filename){
      const blob = new Blob([svgString], {type:'image/svg+xml'});
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = filename;
      document.body.appendChild(a); a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }
    async function copyText(text, btn){
      try{
        await navigator.clipboard.writeText(text);
        if(btn){
          btn.classList.add('copied');
          setTimeout(()=>btn.classList.remove('copied'), 1200);
        }
      }catch(err){
        // Fallback when clipboard is unavailable: let the user copy manually
        console.warn('Copy failed', err);
      }
    }

    // Trigger on right-click
    logoEl.addEventListener('contextmenu', (e)=>{
      e.preventDefault();
      openMenu(e.clientX, e.clientY);
    });

    // Trigger on long-press (mobile)
    let pressTimer = null;
    logoEl.addEventListener('touchstart', (e)=>{
      const touch = e.touches[0];
      pressTimer = setTimeout(()=>{
        openMenu(touch.clientX, touch.clientY);
      }, 500);
    }, {passive:true});
    logoEl.addEventListener('touchend', ()=> clearTimeout(pressTimer));
    logoEl.addEventListener('touchmove', ()=> clearTimeout(pressTimer));

    // Clicks inside the menu
    menu.addEventListener('click', (e)=>{
      const item = e.target.closest('.rcl-item');
      const swatch = e.target.closest('.rcl-swatch');

      if(item){
        const action = item.dataset.action;
        if(action === 'copy-mark') copyText(MARK_SVG, item);
        if(action === 'copy-logo') copyText(LOGO_SVG, item);
        if(action === 'download-mark') { downloadSVG(MARK_SVG, 'grace-mark.svg'); closeMenu(); }
        if(action === 'download-logo') { downloadSVG(LOGO_SVG, 'grace-logo.svg'); closeMenu(); }
        return;
      }
      if(swatch){
        copyText(swatch.dataset.color, swatch);
      }
    });

    // Close on outside click or Esc
    document.addEventListener('click', (e)=>{
      if(!menu.contains(e.target) && e.target !== logoEl && !logoEl.contains(e.target)){
        closeMenu();
      }
    });
    document.addEventListener('keydown', (e)=>{ if(e.key === 'Escape') closeMenu(); });
    window.addEventListener('scroll', closeMenu, {passive:true});
    window.addEventListener('resize', closeMenu);
  })();
</script>

